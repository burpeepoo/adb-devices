{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-cli/schema.json",
  "productName": "ADB Manager",
  "version": "0.1.8",
  "identifier": "com.cozyla.adb-manager",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "ADB Manager",
        "width": 1100,
        "height": 720,
        "resizable": true,
        "center": true,
        "transparent": false,
        "backgroundColor": "#ffffffff"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "resources": [
      "resources/platform-tools"
    ],
    "macOS": {
      "dmg": {
        "background": null
      }
    }
  }
}
