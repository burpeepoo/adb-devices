# Dependencies
node_modules/

# Frontend build output
dist/

# Rust/Tauri build output
src-tauri/target/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# Environment and local config
.env
.env.*
!.env.example
!.env.release.example

# OS/editor noise
.DS_Store
Thumbs.db
.idea/
.vscode/

# Graphify generated cache and rendered viewer
graphify-out/cache/
graphify-out/graph.html
graphify-out/.graphify_python

# Graphify in subdirectories
src-tauri/graphify-out/

# Bundled scrcpy binaries (downloaded by scripts/prepare-scrcpy.sh)
src-tauri/resources/scrcpy/macos-x86_64/*
!src-tauri/resources/scrcpy/macos-x86_64/.gitkeep
src-tauri/resources/scrcpy/macos-aarch64/*
!src-tauri/resources/scrcpy/macos-aarch64/.gitkeep
src-tauri/resources/scrcpy/windows/*
!src-tauri/resources/scrcpy/windows/.gitkeep
